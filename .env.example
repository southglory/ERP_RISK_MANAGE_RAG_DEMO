# -----------------------------------------------------------------------------
# ERP_RISK_MANAGE Configuration Environment Variables
# -----------------------------------------------------------------------------

# --- LLM Provider Settings ---
# Default: Local vLLM (Solar-10.7B). 
# To swap to Upstage Cloud API, use the commented-out values below.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=solar-10.7b-instruct
VLLM_API_KEY=EMPTY

# Example Cloud Swap (Upstage):
# VLLM_BASE_URL=https://api.upstage.ai/v1
# VLLM_MODEL=solar-pro
# VLLM_API_KEY=up_xxxxxxxxxxxxxxxx

# --- Embedding & Reranker Settings (Infinity-emb) ---
# Default local endpoints for BGE-M3 and Reranker
INFINITY_BASE_URL=http://localhost:8001
EMBEDDING_MODEL=bge-m3
RERANKER_MODEL=bge-reranker-v2-m3

# --- Vector Store (Backend Abstraction) ---
# Choice: pgvector (default) | milvus | pinecone
RAG_VECTOR_BACKEND=pgvector

# --- Database Connections ---
# PostgreSQL (pgvector)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=playground
POSTGRES_USER=playground
POSTGRES_PASSWORD=playground
DATABASE_URL=postgresql://playground:playground@localhost:5432/playground

# Milvus (Optional)
MILVUS_HOST=localhost
MILVUS_PORT=19530

# --- Observability (Langfuse) ---
# Tracing and monitoring for LLM calls
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxx

# --- ERP Integration (Optional) ---
ERPNEXT_URL=http://localhost:8080
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# --- Others ---
# HuggingFace Token (Optional: for manual model downloads)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
LOG_LEVEL=INFO
